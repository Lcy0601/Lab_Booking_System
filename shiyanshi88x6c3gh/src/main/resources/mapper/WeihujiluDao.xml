		SELECT  weihujilu.* FROM weihujilu  weihujilu 	        
        <where>${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.yb.entity.view.WeihujiluView" >
		SELECT * FROM weihujilu  weihujilu <where>${ew.sqlSegment}</where>
	</select>
	


</mapper>
