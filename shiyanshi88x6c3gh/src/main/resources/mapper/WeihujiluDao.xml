	<select id="selectListVO"
		resultType="com.yb.entity.vo.WeihujiluVO" >
		SELECT * FROM weihujilu  weihujilu         
        <where>${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.yb.entity.vo.WeihujiluVO" >
		SELECT  weihujilu.* FROM weihujilu  weihujilu 	
 		<where>${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
